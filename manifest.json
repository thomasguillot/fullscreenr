{
	"manifest_version": 3,
	"name": "Fullscreenr",
	"version": "1.0.0",
	"description": "Fullscreen video without blacking out your second display.",
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"permissions": [
		"system.display",
		"tabs"
	],
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_start"
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["injected.js"],
			"matches": ["<all_urls>"]
		}
	]
}